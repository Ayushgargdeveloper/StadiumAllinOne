{
  "name": "stadiumpulse-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier --write \"api/**/*.{ts,tsx}\" \"server/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\" \"*.{js,json,md,css}\"",
    "format:check": "prettier --check \"api/**/*.{ts,tsx}\" \"server/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\" \"*.{js,json,md,css}\"",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "quality": "npm run format:check && npm run lint && npm run coverage && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
